<!-- ═══════════════════════════════════════════════════
     FEATURED PROJECTS SECTION
═══════════════════════════════════════════════════ -->
<section id="projects" class="section" aria-labelledby="projects-heading">
  <div class="max-w-3xl mx-auto px-4 sm:px-6">
    <div class="flex items-end justify-between mb-6">
      <div>
        <h2 id="projects-heading" class="section-label reveal-up">Featured Work</h2>
        <p class="text-xs text-ink-muted mt-1 reveal-up" style="animation-delay:0.05s">Selected client and product projects</p>
      </div>
      <button id="show-all-btn" type="button"
              aria-expanded="false" aria-controls="all-projects-grid"
              class="text-xs text-accent hover:text-accent/80 transition-colors font-medium focus:outline-none focus:ring-2 focus:ring-accent rounded-sm reveal-up">
        View all →
      </button>
    </div>

    <!-- Featured 2-col grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4" role="list" aria-label="Featured portfolio projects">
      {% for project in featured_projects %}
      <article class="project-card reveal-up group" style="animation-delay:{{ loop.index0 * 0.05 }}s" role="listitem">
        <a href="{{ project.link }}" target="{{ '_blank' if project.link != '#' else '_self' }}"
           rel="{{ 'noopener noreferrer' if project.link != '#' }}"
           class="block focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-surface rounded-xl"
           aria-label="{{ project.name }}{% if project.link != '#' %} — view project (opens in new tab){% endif %}">
          <div class="overflow-hidden rounded-xl aspect-[16/9] bg-surface-2 mb-3">
            <img src="{{ project.image }}"
                 alt="{{ project.alt }}"
                 width="600" height="338"
                 class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                 loading="lazy"
                 decoding="async"/>
          </div>
          <div class="px-1">
            <div class="flex items-center justify-between gap-2 mb-1.5">
              <h3 class="text-sm font-semibold text-ink group-hover:text-accent transition-colors duration-200 leading-snug">{{ project.name }}</h3>
              <span class="project-tag project-tag--{{ project.tagColor }}" aria-label="Project category: {{ project.tag }}">{{ project.tag }}</span>
            </div>
            <p class="text-xs text-ink-muted leading-relaxed mb-2.5">{{ project.description }}</p>
            <div class="flex flex-wrap gap-1" aria-label="Technologies used">
              {% for tech in project.stack %}
              <span class="exp-tag">{{ tech }}</span>
              {% endfor %}
            </div>
          </div>
        </a>
      </article>
      {% endfor %}
    </div>

    <!-- All projects (hidden by default) -->
    <div id="all-projects-grid" class="hidden mt-4" aria-label="All portfolio projects">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3" role="list">
        {% for project in all_projects %}
        <article class="project-card-sm reveal-up group" style="animation-delay:{{ loop.index0 * 0.03 }}s" role="listitem">
          <a href="{{ project.link }}" target="{{ '_blank' if project.link != '#' else '_self' }}"
             rel="{{ 'noopener noreferrer' if project.link != '#' }}"
             class="block focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 rounded-lg"
             aria-label="{{ project.name }}{% if project.link != '#' %} (opens in new tab){% endif %}">
            <div class="overflow-hidden rounded-lg aspect-video bg-surface-2 mb-2">
              <img src="{{ project.image }}"
                   alt="{{ project.alt }}"
                   width="400" height="225"
                   class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                   loading="lazy"
                   decoding="async"/>
            </div>
            <h3 class="text-xs font-semibold text-ink group-hover:text-accent transition-colors duration-200 mb-1 truncate">{{ project.name }}</h3>
            <p class="text-[11px] text-ink-muted leading-relaxed line-clamp-2">{{ project.description }}</p>
          </a>
        </article>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

