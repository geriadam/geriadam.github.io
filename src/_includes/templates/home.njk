═══════════════════════════════════════════════════ -->
<section id="about" class="section" aria-labelledby="about-heading">
  <div class="max-w-3xl mx-auto px-4 sm:px-6">
    <h2 id="about-heading" class="section-label reveal-up">About</h2>
    <div class="mt-6 grid sm:grid-cols-5 gap-8 sm:gap-12">
      <div class="sm:col-span-3 reveal-up">
        <p class="text-sm sm:text-base text-ink-muted leading-relaxed mb-4">
          I'm a Fullstack Developer based in Surabaya, Indonesia, with over 7 years of experience delivering web and mobile applications for startups, agencies, and enterprise clients across Indonesia, Europe, and the US.
        </p>
        <p class="text-sm sm:text-base text-ink-muted leading-relaxed mb-4">
          My stack spans the full spectrum — from crafting pixel-perfect UIs with React and Vue to engineering robust backend systems with Laravel and Node.js. I care deeply about performance, accessibility, and code quality that teammates actually enjoy working with.
        </p>
        <p class="text-sm sm:text-base text-ink-muted leading-relaxed">
          When I'm not shipping features, I'm building open-source tools, experimenting with mobile development in React Native, or deepening my knowledge in WebAssembly and edge computing.
        </p>
      </div>
      <div class="sm:col-span-2 reveal-up" style="animation-delay:0.1s">
        <h3 class="text-xs font-semibold uppercase tracking-widest text-ink-muted mb-4">Tech I work with</h3>
        <div class="flex flex-wrap gap-1.5" role="list" aria-label="Technical skills">
          {% set skills = ["JavaScript","TypeScript","React.js","Vue.js","Next.js","Node.js","Laravel","PHP","React Native","MySQL","MongoDB","Docker","GraphQL","REST API","Tailwind CSS","Git","CI/CD","Jest","PHPUnit"] %}
          {% for skill in skills %}
          <span class="skill-pill" role="listitem">{{ skill }}</span>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>

