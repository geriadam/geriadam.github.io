<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover"/>

  <!-- Primary Meta -->
  <title>{{ title | safe | trim }}</title>
  <meta name="description" content="{{ description | safe | trim }}"/>
  <meta name="author" content="Geri Adam Saputra"/>
  <meta name="robots" content="index, follow"/>
  <link rel="canonical" href="https://geriadam.github.io{{ page.url }}"/>
  <meta name="keywords" content="Fullstack Developer, React, Vue, Laravel, Node.js, TypeScript, JavaScript, Surabaya, Indonesia"/>

  <!-- Open Graph -->
  <meta property="og:type" content="website"/>
  <meta property="og:url" content="https://geriadam.github.io{{ page.url }}"/>
  <meta property="og:title" content="{{ title | safe | trim }}"/>
  <meta property="og:description" content="{{ description | safe | trim }}"/>
  <meta property="og:image" content="https://geriadam.github.io/dist/assets/img/profile.png"/>
  <meta property="og:locale" content="en_US"/>
  <meta property="og:site_name" content="Geri Adam Saputra — Fullstack Developer"/>

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image"/>
  <meta name="twitter:title" content="{{ title | safe | trim }}"/>
  <meta name="twitter:description" content="{{ description | safe | trim }}"/>
  <meta name="twitter:image" content="https://geriadam.github.io/dist/assets/img/profile.png"/>

  <!-- Schema.org Person -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Geri Adam Saputra",
    "url": "https://geriadam.github.io",
    "jobTitle": "Fullstack Developer",
    "description": "Results-driven Fullstack Developer with 7+ years building scalable web applications across startup and enterprise environments.",
    "email": "geriadam04@gmail.com",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Surabaya",
      "addressCountry": "ID"
    },
    "alumniOf": {
      "@type": "CollegeOrUniversity",
      "name": "Institut Teknologi Adhi Tama Surabaya"
    },
    "sameAs": [
      "https://linkedin.com/in/geri-adam-saputra",
      "https://github.com/geriadam"
    ],
    "knowsAbout": ["JavaScript","TypeScript","React.js","Vue.js","Laravel","Node.js","REST API","Docker","GraphQL"]
  }
  </script>

  <!-- Preconnect -->
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet"/>

  <link href="/styles.css" rel="stylesheet"/>
  <link rel="shortcut icon" href="/dist/assets/img/favicon.ico"/>

  <!-- Prevent FOUC for dark mode -->
  <script>
    (function() {
      var s = localStorage.getItem('theme');
      var d = window.matchMedia('(prefers-color-scheme: dark)').matches;
      if (s === 'dark' || (!s && d)) document.documentElement.classList.add('dark');
    })();
  </script>
</head>
<body class="bg-surface text-ink antialiased transition-colors duration-300 min-h-screen">

  <!-- Skip link (WCAG 2.4.1) -->
  <a href="#main-content"
     class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-1/2 focus:-translate-x-1/2 focus:z-[100] focus:px-5 focus:py-2.5 focus:bg-accent focus:text-white focus:rounded-full focus:text-sm focus:font-medium focus:shadow-lg focus:outline-none">
    Skip to main content
  </a>

  <!-- Page loader -->
  <div id="page-loader" role="presentation" aria-hidden="true"
       class="fixed inset-0 z-[999] flex items-center justify-center bg-surface">
    <div class="flex flex-col items-center gap-4">
      <div class="w-8 h-8 border-2 border-ink-muted/30 border-t-accent rounded-full animate-spin"></div>
      <span class="font-mono text-xs text-ink-muted tracking-widest uppercase">Loading</span>
    </div>
  </div>

  <!-- Header -->
  <header id="site-header" class="fixed top-0 left-0 right-0 z-40 transition-all duration-300" role="banner">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <nav class="h-14 flex items-center justify-between" aria-label="Primary navigation">
        <a href="#hero"
           class="font-mono text-sm font-medium text-ink hover:text-accent transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-surface rounded-sm"
           aria-label="Geri Adam Saputra — back to top">
          geri<span class="text-accent" aria-hidden="true">.</span>dev
        </a>
        <div class="flex items-center gap-1">
          <!-- Desktop nav -->
          <ul class="hidden sm:flex items-center" role="list">
            <li><a href="#about" class="nav-link">About</a></li>
            <li><a href="#experience" class="nav-link">Experience</a></li>
            <li><a href="#projects" class="nav-link">Projects</a></li>
            <li><a href="#github" class="nav-link">GitHub</a></li>
            <li><a href="#contact" class="nav-link">Contact</a></li>
          </ul>
          <!-- Theme toggle -->
          <button id="theme-toggle" type="button" aria-label="Switch to dark mode"
                  class="p-2 rounded-lg text-ink-muted hover:text-ink hover:bg-surface-2 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-surface">
            <!-- Sun (shown in dark mode) -->
            <svg class="hidden dark:block" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
            <!-- Moon (shown in light mode) -->
            <svg class="block dark:hidden" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
          </button>
          <!-- Mobile menu button -->
          <button id="mobile-menu-btn" type="button" aria-label="Open navigation menu" aria-expanded="false" aria-controls="mobile-nav"
                  class="sm:hidden p-2 rounded-lg text-ink-muted hover:text-ink hover:bg-surface-2 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-surface">
            <svg id="hamburger-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" aria-hidden="true"><line x1="4" y1="6" x2="20" y2="6"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="18" x2="20" y2="18"/></svg>
            <svg id="close-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" aria-hidden="true" class="hidden"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </button>
        </div>
      </nav>
    </div>
    <!-- Mobile menu panel -->
    <div id="mobile-nav" class="sm:hidden hidden" role="dialog" aria-modal="true" aria-label="Mobile navigation">
      <div class="border-t border-border bg-surface/95 backdrop-blur-sm">
        <nav class="max-w-3xl mx-auto px-4 py-4 flex flex-col gap-0.5" aria-label="Mobile navigation links">
          <a href="#about" class="mobile-nav-link">About</a>
          <a href="#experience" class="mobile-nav-link">Experience</a>
          <a href="#projects" class="mobile-nav-link">Projects</a>
          <a href="#github" class="mobile-nav-link">GitHub</a>
          <a href="#contact" class="mobile-nav-link">Contact</a>
        </nav>
      </div>
    </div>
  </header>

  <main id="main-content" class="pt-14" tabindex="-1">
    {% block content %}{% endblock %}
  </main>

  <footer class="border-t border-border mt-20 py-10" role="contentinfo">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-ink-muted">
      <p>© 2025 <span class="text-ink font-medium">Geri Adam Saputra</span>. Built with Eleventy & Tailwind CSS.</p>
      <a href="https://github.com/geriadam/geriadam.github.io" target="_blank" rel="noopener noreferrer"
         class="hover:text-accent transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-accent rounded-sm"
         aria-label="View portfolio source code on GitHub (opens in new tab)">
        View source →
      </a>
    </div>
  </footer>

  <script src="/js/main.js" defer></script>
</body>
</html>
